# Kredit Lab OCR service / OpenIngest environment variables
#
# Copy this file to `.env` and fill in only the providers you use.
#
#   cp .env.example .env
#   set -a; source .env; set +a

# ----- Kredit Lab OCR service -------------------------------------------------
# Optional but strongly recommended. The dashboard sends the same SERVICE_API_KEY
# value when calling POST /parse.
SERVICE_API_KEY=

# Primary OCR backend for service/app.py.
OCR_MODEL=azure-di

# Backup OCR provider. Leave blank for Azure-only behavior.
LLMWHISPERER_API_KEY=
LLMWHISPERER_MODE=form
LLMWHISPERER_BASE=https://llmwhisperer-api.us-central.unstract.com/api/v2


# ----- OCR provider: Azure Document Intelligence (azure-di) ------------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=


# ----- Legacy OpenIngest resource override -----------------------------------
# Kept because existing deployments may already define it. service/app.py does
# not require this variable for Azure OCR.
TENSORLAKE_MIN_CONTAINERS=0


# ----- OCR provider: AWS Textract (textract) ---------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=


# ----- OCR provider: Gemini VLM (gemini) -------------------------------------
GEMINI_API_KEY=


# ----- VLM / LLM enrichment ---------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QWEN_API_KEY=


# ----- Optional Azure OpenAI for cross-page header correction ----------------
USE_AZURE_OPENAI=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL_DEPLOYMENT_NAME=


# ----- Resource overrides (optional, dots-ocr only) --------------------------
OCR_GPU_MEMORY_IN_GB=32
OVIS_MEMORY_IN_GB=24
